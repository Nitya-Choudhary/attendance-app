{
  "version": 2,
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "other",
  "env": {
    "DATABASE_URL": {
      "description": "MySQL/TiDB database connection string"
    },
    "VITE_APP_ID": {
      "description": "Manus OAuth application ID"
    },
    "JWT_SECRET": {
      "description": "JWT secret key for session signing"
    },
    "OAUTH_SERVER_URL": {
      "description": "Manus OAuth server URL"
    },
    "BUILT_IN_FORGE_API_KEY": {
      "description": "Manus built-in API key for backend services"
    },
    "BUILT_IN_FORGE_API_URL": {
      "description": "Manus built-in API URL"
    },
    "VITE_FRONTEND_FORGE_API_KEY": {
      "description": "Frontend API key for Manus services"
    },
    "VITE_FRONTEND_FORGE_API_URL": {
      "description": "Frontend API URL for Manus services"
    },
    "VITE_OAUTH_PORTAL_URL": {
      "description": "Manus OAuth portal URL"
    },
    "VITE_APP_TITLE": {
      "description": "Application title"
    },
    "VITE_APP_LOGO": {
      "description": "Application logo URL"
    },
    "OWNER_NAME": {
      "description": "Owner name"
    },
    "OWNER_OPEN_ID": {
      "description": "Owner's Manus OpenID"
    }
  },
  "functions": {
    "server/_core/index.ts": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/_core/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "dist/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, immutable"
        }
      ]
    }
  ]
}
